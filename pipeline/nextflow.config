/*
 * Global default parameters
 */
params {
    reads  = "data/*_{1,2}.fastq.gz"
    outdir = "results"
    genome = "data/reference/hg38.fa"
}

/*
 * Execution Profiles
 */
profiles {
    docker {
        docker.enabled       = true
        docker.userEmulation = true
        // Assuming you build your Dockerfile and tag it locally, or use a public bioinformatics image
        process.container    = 'ubuntu:22.04' 
    }
    
    local {
        process.executor = 'local'
    }
}

/*
 * Process-specific resource allocations
 */
process {
    withName: 'ALIGN_READS' {
        cpus   = 4
        memory = '8 GB'
    }
    
    withName: 'SORT_BAM' {
        cpus   = 2
        memory = '4 GB'
    }
}